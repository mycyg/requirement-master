DATABASE_URL=sqlite:////srv/yqgl/data/yqgl.db
DATA_DIR=/srv/yqgl/data
APP_ENV=production
COOKIE_SECRET=change-me-to-a-long-random-string
# Set true ONLY when serving over HTTPS. The default LAN deploy is plain HTTP
# (http://192.168.5.53:8080) — a Secure cookie is dropped by the browser over
# HTTP, which silently breaks login. Keep false for HTTP-on-LAN; flip to true
# the moment you put TLS in front.
COOKIE_SECURE=false
CORS_ALLOW_ORIGINS=["https://your-domain.example"]

LLM_BASE_URL=https://api.deepseek.com/anthropic
LLM_MODEL=deepseek-v4-pro
LLM_API_KEY=sk-replace-me-with-your-deepseek-key

ASR_BASE_URL=http://127.0.0.1:8001
ASR_MODEL=Qwen/Qwen3-ASR-1.7B

INTERNAL_BASE_URL=http://127.0.0.1:8080
